RewriteEngine On
RewriteBase /

# --- Rotas de API ---
RewriteRule ^api/(.*)$ api/public/index.php [L,QSA]

# --- Raiz do domínio: serve o front estático ---
RewriteRule ^/?$ public/index.html [L]

# --- Arquivos estáticos existentes do front: serve direto ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/).*$ public/index.html [L]

DirectoryIndex public/index.html