RewriteEngine On

# Redireciona as rotas da API para o entrypoint PHP
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/?(.*)$ api/public/index.php [L,QSA]

# Para tudo o que não for arquivo, pasta ou rota da API, serve o frontend
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.html [L]
